# ShipSmart Infra - aggregated environment variables for local development.
#
# This file lists every env var needed across the 4 repos. Copy the relevant
# sections into each repo's own .env file:
#   - VITE_* -> ShipSmart-Web/.env.local
#   - Java vars -> ShipSmart-Orchestrator/.env
#   - Python vars -> ShipSmart-API/.env
#
# Production values live in the Render dashboard, never in these files.

# Web (ShipSmart-Web/.env.local)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_JAVA_API_BASE_URL=http://localhost:8080
VITE_PYTHON_API_BASE_URL=http://localhost:8000
VITE_APP_ENV=development
VITE_USE_JAVA_QUOTES=true
VITE_USE_JAVA_SAVED_OPTIONS=true
VITE_USE_JAVA_BOOKING_REDIRECT=true
VITE_SHIPPING_SCOPE=worldwide        # worldwide (default) | domestic (hide country fields + duties)
VITE_DOMESTIC_COUNTRY=US             # home country shown when VITE_SHIPPING_SCOPE=domestic

# Orchestrator / Java (ShipSmart-Orchestrator/.env)
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
REQUIRE_JWT_SECRET=false
DATABASE_URL=jdbc:postgresql://db.your-project-ref.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=your-supabase-db-user
DATABASE_PASSWORD=your-supabase-db-password
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
CORS_ALLOWED_ORIGINS=http://localhost:5173
INTERNAL_PYTHON_API_URL=http://localhost:8000
SHIPPING_SCOPE=worldwide             # worldwide (default) | domestic (suppress international carrier lanes); maps to shipsmart.shipping.scope
FEDEX_BASE_URL=https://apis.fedex.com
FEDEX_CLIENT_ID=your-fedex-client-id
FEDEX_CLIENT_SECRET=your-fedex-client-secret
FEDEX_ACCOUNT_NUMBER=your-fedex-account-number

# API / Python (ShipSmart-API/.env)
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
INTERNAL_JAVA_API_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173
VECTOR_STORE_TYPE=pgvector
DATABASE_URL=postgresql://user:pass@project-ref.pooler.supabase.com:6543/postgres?sslmode=require
PGVECTOR_TABLE=rag_chunks
MCP_SERVER_URL=
MCP_API_KEY=
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
LLAMA_BASE_URL=http://localhost:11434
LLAMA_MODEL=llama3.2
LLM_PROVIDER_REASONING=openai
LLM_PROVIDER_SYNTHESIS=openai
LLM_PROVIDER_FALLBACK=echo
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_AUTO_INGEST=true
RAG_DOCUMENTS_PATH=data/documents
RAG_TOP_K=3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
# Retrieval (hybrid + agentic) — defaults reproduce today's dense-only, normal mode
RAG_MODE=normal                  # normal | agentic
RAG_HYBRID=false                 # false = dense-only (today), true = dense+sparse
RAG_HYBRID_ALPHA=0.5             # dense vs sparse fusion weight (0..1; 1.0 = all dense)
RAG_AGENTIC_MAX_STEPS=3          # max plan/retrieve steps when RAG_MODE=agentic
RAG_QUERY_LOG=false             # true = write agentic traces to rag_query_log (needs Infra migration)
# LLM context + fallback chain
LLM_MAX_CONTEXT_TOKENS=8000      # token budget for retrieved context fed to the LLM
LLM_FALLBACK_CHAIN=              # csv, e.g. openai,gemini,echo (empty = today: no fallback)
LLM_RETRY_MAX_ATTEMPTS=2         # attempts per provider before moving down the chain
# Per-task overrides (optional; empty = use the existing provider/global default)
LLM_MODEL_REASONING=             # model override for the reasoning task
LLM_MODEL_SYNTHESIS=             # model override for the synthesis task
LLM_TEMPERATURE_REASONING=       # temperature override for reasoning (keep 0.0–0.3)
LLM_TEMPERATURE_SYNTHESIS=       # temperature override for synthesis (keep 0.0–0.3)
LLM_MAX_TOKENS_REASONING=        # max output tokens for reasoning
LLM_MAX_TOKENS_SYNTHESIS=        # max output tokens for synthesis
# Guardrails
GUARDRAILS_ENABLED=true          # run input/output guardrails on advisor/RAG calls
GUARDRAILS_BLOCK_ON_INJECTION=true  # block when prompt-injection is detected (requires GUARDRAILS_ENABLED)
SHIPPING_PROVIDER=mock
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_BASE_URL=https://onlinetools.ups.com
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_BASE_URL=https://apis.fedex.com
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_BASE_URL=https://express.api.dhl.com
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=
USPS_BASE_URL=https://api.usps.com
ENABLE_TOOLS=true
RATE_LIMIT_ADVISOR=10/minute
RATE_LIMIT_ORCHESTRATION=20/minute
RATE_LIMIT_COMPARE=10/minute
RATE_LIMIT_COMPLIANCE=10/minute
RATE_LIMIT_WORKFLOW=10/minute

# Audit + tracing sink: logging (default — structured log lines) | memory
AUDIT_SINK=logging

# Shipping scope (platform policy) — worldwide (default) | domestic. domestic =
# deliveries within DOMESTIC_COUNTRY only (API rejects cross-border with 422 and
# publishes the mode on GET /api/v1/info; ShipSmart-MCP reads the same vars).
SHIPPING_SCOPE=worldwide
DOMESTIC_COUNTRY=US

# Compliance (UC2) — deterministic structural + grounded-area analysis with an
# optional model-driven critic (POST /api/v1/compliance/check). Advisory only.
COMPLIANCE_ENABLED=true              # gate the compliance endpoint (404 when false)
COMPLIANCE_EXPLICIT_ENABLED=true     # additive: run the hard compliance pass on chat/workflow; false = normal flow only (skips the workflow HITL interrupt)
COMPLIANCE_CRITIQUE_MAX_ROUNDS=0     # 0 = critic off (deterministic only); >0 enables the UC2 critic
COMPLIANCE_MAX_GAP_AREAS=3           # max gap areas accepted from the critic per round
COMPLIANCE_VALUE_THRESHOLD_USD=2500  # declared value (USD) that flags a commercial invoice (international)

# Workflow (UC3/UC4) — multi-agent durable workflow + human-in-the-loop. OFF by default.
WORKFLOW_ENABLED=false               # gate the workflow endpoints (404 when false)
WORKFLOW_DURABLE=false               # false = in-memory checkpointer; true = SQLite (survives restarts)
WORKFLOW_CHECKPOINT_PATH=workflow_checkpoints.db   # SQLite file when WORKFLOW_DURABLE=true
WORKFLOW_HIGH_RISK_AREAS=lithium_battery,import_restriction  # unverified area here → human review

# Conversational Concierge — multi-turn shipment-setup assistant (POST /api/v1/concierge/chat).
# Drives the workflow above for international shipments when compliance+workflow are on.
CONCIERGE_ENABLED=false              # gate the concierge endpoint (404 when false)
CONCIERGE_MAX_TURNS=12              # soft bound on a single conversation
CONVERSATION_STORE=memory          # recall store: memory (keyless) | postgres (asyncpg + DATABASE_URL)
CONVERSATION_MAX_MESSAGES=50       # recall window: max transcript turns loaded
