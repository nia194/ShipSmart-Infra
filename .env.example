# ShipSmart Infra — aggregated environment variables for local development.
#
# This file lists every env var needed across the 4 repos. Copy the relevant
# sections into each repo's own .env file:
#   - VITE_* → ShipSmart-Web/.env.local
#   - Java vars → ShipSmart-Orchestrator/.env
#   - Python vars → ShipSmart-API/.env
#
# Production values live in the Render dashboard, never in these files.

# ─── Web (ShipSmart-Web/.env.local) ──────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_JAVA_API_BASE_URL=http://localhost:8080
VITE_PYTHON_API_BASE_URL=http://localhost:8000
VITE_APP_ENV=development
VITE_USE_JAVA_QUOTES=true
VITE_USE_JAVA_SAVED_OPTIONS=true
VITE_USE_JAVA_BOOKING_REDIRECT=true

# ─── Orchestrator / Java (ShipSmart-Orchestrator/.env) ───────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local
REQUIRE_JWT_SECRET=true
DATABASE_URL=jdbc:postgresql://db.your-project-ref.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=your-supabase-db-user
DATABASE_PASSWORD=your-supabase-db-password
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
CORS_ALLOWED_ORIGINS=http://localhost:5173
INTERNAL_PYTHON_API_URL=http://localhost:8000
FEDEX_BASE_URL=https://apis.fedex.com
FEDEX_CLIENT_ID=your-fedex-client-id
FEDEX_CLIENT_SECRET=your-fedex-client-secret
FEDEX_ACCOUNT_NUMBER=your-fedex-account-number

# ─── API / Python (ShipSmart-API/.env) ───────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY — reuse values from Java section
INTERNAL_JAVA_API_URL=http://localhost:8080
# CORS_ALLOWED_ORIGINS — reuse value from Java section
VECTOR_STORE_TYPE=memory
# DATABASE_URL (Postgres async form, for pgvector):
# postgresql://user:pass@project-ref.pooler.supabase.com:6543/postgres?sslmode=require
PGVECTOR_TABLE=rag_chunks
LLM_PROVIDER=
OPENAI_API_KEY=
LLM_PROVIDER_REASONING=
LLM_PROVIDER_SYNTHESIS=
LLM_PROVIDER_FALLBACK=echo
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RAG_AUTO_INGEST=true
RAG_DOCUMENTS_PATH=data/documents
RAG_TOP_K=3
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
SHIPPING_PROVIDER=mock
ENABLE_TOOLS=true
